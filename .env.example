# Zoho OAuth app credentials — from https://api-console.zoho.com/
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Your Zoho Mail account ID — run: GET https://mail.zoho.com/api/accounts
# Use the accountId from the first object in data[]
ZOHO_ACCOUNT_ID=

# The email address to send from (must be a verified address or alias on this account)
ZOHO_SENDER=
